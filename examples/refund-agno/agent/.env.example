# Copy to .env. The Makefile loads this file automatically.

# Provider selector. Default is "offline" (deterministic, no AWS needed).
# Set to "bedrock" for the real-LLM demo.
AGNO_MODEL_PROVIDER=offline

# Bedrock + AWS configuration (only used when AGNO_MODEL_PROVIDER=bedrock).
# Mirrors the-line/apps/agent-runtime defaults.
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# KIFF demo server URL. The Makefile starts the server on a free port and
# overrides KIFF_BASE_URL automatically; only set this when running the
# agent against a long-lived server you started yourself.
# KIFF_BASE_URL=http://localhost:8080

# Identifier the runner uses when posting proposals to KIFF. The server
# already knows the agent actor; this is reserved for future per-tenant
# wiring and is currently informational.
KIFF_AGENT_ACTOR_ID=support-agent

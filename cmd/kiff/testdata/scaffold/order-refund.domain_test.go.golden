package domain

import (
	"context"
	"errors"
	"testing"
	"time"

	"github.com/kiff/kiff/pkg/kiff/action"
	"github.com/kiff/kiff/pkg/kiff/adapter"
	"github.com/kiff/kiff/pkg/kiff/approval"
)

// TestLoop_HappyPath drives the Order through its state machine, granting
// approvals where required, and asserts the final state.
func TestLoop_HappyPath(t *testing.T) {
	ctx := context.Background()
	rt, err := NewRuntime()
	if err != nil {
		t.Fatalf("NewRuntime: %v", err)
	}

	const entityID = "refund-1"

	if _, err := rt.IngestRaw(ctx, adapter.RawInput{
		ID:         "evt-bootstrap",
		Adapter:    AdapterRefund,
		Type:       EventOrderPlaced,
		Source:     "refund/test",
		EntityID:   entityID,
		EntityType: EntityOrder,
		ActorID:    SystemActor.ID,
		ReceivedAt: time.Now().UTC(),
	}); err != nil {
		t.Fatalf("IngestRaw(bootstrap): %v", err)
	}

	// Step 0: MARK_PAID (StateCreated -> StatePaid)
	{
		contract, ok := rt.Actions.Get(ActionMarkPaid)
		if !ok {
			t.Fatalf("missing contract MARK_PAID")
		}
		actionCtx := action.ActionContext{
			ActionName:   ActionMarkPaid,
			EntityID:     entityID,
			EntityType:   EntityOrder,
			CurrentState: StateCreated,
			Actor:        AgentActor,
			Parameters:   map[string]any{"payment_id": "sample-payment_id"},
		}
		result, err := rt.ExecuteAction(ctx, actionCtx, contract)
		if err != nil {
			t.Fatalf("ExecuteAction(MARK_PAID): %v", err)
		}
		if result.Status != action.ExecutionSucceeded {
			t.Fatalf("MARK_PAID: expected succeeded, got %s", result.Status)
		}
	}

	// Step 1: REFUND_ORDER (StatePaid -> StateRefunded)
	{
		contract, ok := rt.Actions.Get(ActionRefundOrder)
		if !ok {
			t.Fatalf("missing contract REFUND_ORDER")
		}
		actionCtx := action.ActionContext{
			ActionName:   ActionRefundOrder,
			EntityID:     entityID,
			EntityType:   EntityOrder,
			CurrentState: StatePaid,
			Actor:        AgentActor,
			Parameters:   map[string]any{"amount": "sample-amount", "reason": "sample-reason"},
			ApprovalID:   "approval-1",
		}
		if _, err := rt.RequestApproval(ctx, actionCtx.ApprovalID, actionCtx, contract, "scaffold happy path"); err != nil {
			t.Fatalf("RequestApproval(REFUND_ORDER): %v", err)
		}
		if _, err := rt.ReviewApproval(ctx, actionCtx.ApprovalID, OperatorActor.ID, approval.StatusGranted, "approved"); err != nil {
			t.Fatalf("ReviewApproval(REFUND_ORDER): %v", err)
		}
		result, err := rt.ExecuteAction(ctx, actionCtx, contract)
		if err != nil {
			t.Fatalf("ExecuteAction(REFUND_ORDER): %v", err)
		}
		if result.Status != action.ExecutionSucceeded {
			t.Fatalf("REFUND_ORDER: expected succeeded, got %s", result.Status)
		}
	}

	current, _, err := rt.States.Current(ctx, entityID)
	if err != nil {
		t.Fatalf("States.Current: %v", err)
	}
	if current.Value != StateRefunded {
		t.Fatalf("expected final state %q, got %q", StateRefunded, current.Value)
	}
}

func TestMarkPaid_AllowedState(t *testing.T) {
	policy := NewPermissionPolicy()
	actionCtx := action.ActionContext{
		ActionName:   ActionMarkPaid,
		EntityID:     "entity-allowed",
		EntityType:   EntityOrder,
		CurrentState: StateCreated,
		Actor:        AgentActor,
		Parameters:   map[string]any{"payment_id": "sample-payment_id"},
	}
	_, err := action.DefaultValidator{}.Validate(context.Background(), actionCtx, markPaidContract(), policy)
	if err != nil {
		t.Fatalf("expected validation to pass in allowed state, got %v", err)
	}
}

func TestMarkPaid_BlockedFromWrongState(t *testing.T) {
	policy := NewPermissionPolicy()
	actionCtx := action.ActionContext{
		ActionName:   ActionMarkPaid,
		EntityID:     "entity-blocked",
		EntityType:   EntityOrder,
		CurrentState: StatePaid,
		Actor:        AgentActor,
		Parameters:   map[string]any{"payment_id": "sample-payment_id"},
	}
	_, err := action.DefaultValidator{}.Validate(context.Background(), actionCtx, markPaidContract(), policy)
	if !errors.Is(err, action.ErrStateNotAllowed) {
		t.Fatalf("expected ErrStateNotAllowed from wrong state, got %v", err)
	}
}

func TestRefundOrder_AllowedState(t *testing.T) {
	policy := NewPermissionPolicy()
	actionCtx := action.ActionContext{
		ActionName:   ActionRefundOrder,
		EntityID:     "entity-allowed",
		EntityType:   EntityOrder,
		CurrentState: StatePaid,
		Actor:        AgentActor,
		Parameters:   map[string]any{"amount": "sample-amount", "reason": "sample-reason"},
	}
	_, err := action.DefaultValidator{}.Validate(context.Background(), actionCtx, refundOrderContract(), policy)
	// Allowed in this state, but the approval gate must hold until granted.
	if !errors.Is(err, action.ErrApprovalRequired) {
		t.Fatalf("expected ErrApprovalRequired in allowed state, got %v", err)
	}
}

func TestRefundOrder_BlockedFromWrongState(t *testing.T) {
	policy := NewPermissionPolicy()
	actionCtx := action.ActionContext{
		ActionName:   ActionRefundOrder,
		EntityID:     "entity-blocked",
		EntityType:   EntityOrder,
		CurrentState: StateCreated,
		Actor:        AgentActor,
		Parameters:   map[string]any{"amount": "sample-amount", "reason": "sample-reason"},
	}
	_, err := action.DefaultValidator{}.Validate(context.Background(), actionCtx, refundOrderContract(), policy)
	if !errors.Is(err, action.ErrStateNotAllowed) {
		t.Fatalf("expected ErrStateNotAllowed from wrong state, got %v", err)

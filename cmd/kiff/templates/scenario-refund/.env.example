# Copy to .env and adjust. Used by docker-compose.yml and the server's
# -store=postgres mode. Credentials are never hard-coded in the source.
POSTGRES_USER=kiff
POSTGRES_PASSWORD=kiff
POSTGRES_DB=kiff
POSTGRES_PORT=5432

# The server reads DATABASE_URL when run with -store=postgres.
DATABASE_URL=postgres://kiff:kiff@localhost:5432/kiff?sslmode=disable
